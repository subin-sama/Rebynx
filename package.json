{
  "name": "rebynx",
  "version": "0.1.0",
  "private": true,
  "description": "Hybrid devtools for React Native — in-app overlay + browser client from one engine.",
  "keywords": [
    "react-native",
    "devtools",
    "debugging",
    "rebynx"
  ],
  "license": "MIT",
  "author": "Bynx",
  "homepage": "https://github.com/bynx/rebynx#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bynx/rebynx.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @rebynx/core && npm run build --workspace @rebynx/server",
    "build:core": "npm run build --workspace @rebynx/core",
    "build:server": "npm run build --workspace @rebynx/server",
    "install:rn-app": "npm run build:core && node scripts/install-rn-app.mjs",
    "server": "npm run start --workspace @rebynx/server",
    "server:dev": "npm run dev --workspace @rebynx/server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run"
  },
  "devDependencies": {
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "npm@11.12.1"
}
